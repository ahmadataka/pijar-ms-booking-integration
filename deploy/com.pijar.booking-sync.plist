<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pijar.booking-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>"$HOME/Library/Application Support/PIJARBookingSync/scripts/run-production-sync.sh"</string>
  </array>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/ahmadataka/Library/Application Support/PIJARBookingSync</string>

  <key>StandardOutPath</key>
  <string>/Users/ahmadataka/Library/Application Support/PIJARBookingSync/data/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/ahmadataka/Library/Application Support/PIJARBookingSync/data/logs/launchd.err.log</string>
</dict>
</plist>
